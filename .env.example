# SAP AI Core — copy to .env for local dev (see course Doc 11)
# On BTP: set the same keys as CF env vars on healthcare-audit-assistant-srv

# OAuth token URL (client_credentials) — your BTP subaccount
AI_TOKEN_URL=https://btpailearning.authentication.us10.hana.ondemand.com/oauth/token?grant_type=client_credentials&response_type=token

# AI Core deployment chat/completions endpoint from your course tenant
AI_DEPLOYMENT_URL=https://api.ai.prod.us-east-1.aws.ml.hana.ondemand.com/v2/inference/deployments/<deployment-id>/chat/completions?api-version=2023-05-15

AI_RESOURCE_GROUP=default

# Service binding client id / secret (AI Core or tutorial credentials)
USERNAME=
PASSWORD=
