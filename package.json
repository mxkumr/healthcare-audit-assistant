{
  "name": "healthcare-audit-assistant",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.4",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.13.0",
    "rimraf": "^5.0.5",
    "mbt": "^1.2.49"
  },
  "scripts": {
    "postinstall": "node scripts/ensure-mbt.js",
    "start": "npx cds-serve",
    "watch": "npx cds watch",
    "watch-1.1cost-analysis": "npx cds watch --open com.medicare.11costanalysis/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-1.2rural-analysis": "npx cds watch --open com.medicare.12ruralanalysis/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy healthcare-audit-assistant --delete-services --delete-service-keys --delete-service-brokers",
    "build": "node scripts/ensure-mbt.js && node scripts/fix-html5-bootstrap.js && node scripts/ensure-html5-deploy.js && node scripts/generate-mta-html5.js && rm -rf resources mta_archives && npx mbt build --mtar archive",
    "ensure-mbt": "node scripts/ensure-mbt.js",
    "sanitize-data": "node scripts/sanitize-csv-for-hana.js",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1",
    "watch-2.1provider-classification": "npx cds watch --open com.medicare.21providerclassification/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-2.2aspecialty-profiling": "npx cds watch --open com.medicare.22aspecialtyprofiling/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-2.2borganization-profiling": "npx cds watch --open com.medicare.22borganizationprofiling/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-task1-overview": "npx cds watch --open com.medicare.task1overview/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-risk-analysis": "npx cds watch --open com.medicare.riskanalysis/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-task2-overview": "npx cds watch --open com.medicare.task2overview/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-1.3behavioral-helath-risk": "npx cds watch --open com.medicare.13behavioralhelathrisk/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-3.1risk-dynamics": "npx cds watch --open com.medicare.31riskdynamics/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-3.2place-of-service": "npx cds watch --open com.medicare.32placeofservice/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-3.3credential-discrepancies": "npx cds watch --open com.medicare.33credentialdiscrepancies/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-audit-home": "npx cds watch --open com.medicare.audithome/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-task3-overview": "npx cds watch --open com.medicare.task3overview/index.html?sap-ui-xx-viewCache=false --livereload false",
    "test-agent": "curl -s -X POST http://localhost:4004/medicare/listAuditYears -H 'Content-Type: application/json' -d '{}' && echo && curl -s -X POST http://localhost:4004/medicare/investigateAnomalies -H 'Content-Type: application/json' -d '{\"prompt\":\"CA Pain Management audit\",\"year\":\"2022\",\"state\":\"CA\",\"specialty\":\"Pain Management\",\"npi\":\"1003056821\"}'"
  },
  "private": true,
  "cds": {
    "requires": {
      "[development]": {
        "auth": {
          "kind": "mocked",
          "users": {
            "audit.admin@tester.sap.com": {
              "password": "initial",
              "roles": ["admin"]
            },
            "audit.analyst@tester.sap.com": {
              "password": "initial",
              "roles": ["audit_analyst"]
            }
          }
        }
      },
      "[production]": {
        "auth": "xsuaa",
        "db": "hana"
      }
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/1.1cost-analysis",
    "app/1.2rural-analysis",
    "app/2.1provider-classification",
    "app/2.2aspecialty-profiling",
    "app/2.2borganization-profiling",
    "app/task1-overview",
    "app/1.3behavioral-helath-risk",
    "app/risk-analysis",
    "app/task2-overview",
    "app/3.1risk-dynamics",
    "app/3.2place-of-service",
    "app/3.3credential-discrepancies",
    "app/audit-home",
    "app/task3-overview"
  ]
}
