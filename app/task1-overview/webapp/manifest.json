{
  "_version": "1.85.0",
  "sap.app": {
    "id": "com.medicare.task1overview",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:ovp",
      "version": "1.25.0",
      "toolsId": "d21c8958-427d-42a4-9ad9-87a29846902e"
    },
    "dataSources": {
      "mainService": {
        "uri": "/medicare/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.148.1",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {},
        "sap.ovp": {},
        "sap.ui.rta": {},
        "sap.ui.layout": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "com.medicare.task1overview.i18n.i18n"
        }
      },
      "mainModel": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": []
    },
    "routing": {
      "config": {},
      "routes": [],
      "targets": {}
    }
  },
  "sap.ovp": {
    "globalFilterModel": "mainModel",
    "globalFilterEntitySet": "CostAnalysisV2",
    "containerLayout": "resizable",
    "enableLiveFilter": true,
    "considerAnalyticalParameters": false,
    "cards": {
      "card00_cost": {
        "model": "mainModel",
        "template": "sap.ovp.cards.v4.charts.analytical",
        "settings": {
          "title": "Cost by State",
          "subTitle": "Total Paid ($) per State",
          "entitySet": "CostAnalysisV2",
          "addODataSelect": true,
          "chartAnnotationPath": "com.sap.vocabularies.UI.v1.Chart#V2Footprint",
          "presentationAnnotationPath": "com.sap.vocabularies.UI.v1.PresentationVariant#V2Chart"
        }
      },
      "card01_rural": {
        "model": "mainModel",
        "template": "sap.ovp.cards.v4.charts.analytical",
        "settings": {
          "title": "Rural vs Urban",
          "subTitle": "Total Paid ($) by locality type",
          "entitySet": "RuralUrbanDistribution",
          "addODataSelect": true,
          "chartAnnotationPath": "com.sap.vocabularies.UI.v1.Chart",
          "presentationAnnotationPath": "com.sap.vocabularies.UI.v1.PresentationVariant"
        }
      },
      "card02_risk": {
        "model": "mainModel",
        "template": "sap.ovp.cards.v4.charts.analytical",
        "settings": {
          "title": "Cost-Complexity Frontier",
          "subTitle": "Risk score vs. paid per beneficiary by BH group",
          "entitySet": "BehavioralHealthRiskProfile",
          "addODataSelect": true,
          "chartAnnotationPath": "com.sap.vocabularies.UI.v1.Chart#CostComplexityFrontier",
          "presentationAnnotationPath": "com.sap.vocabularies.UI.v1.PresentationVariant#FrontierChart"
        }
      }
    },
    "globalFilterControlType": "MacroFilterBar"
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "analytical"
  },
  "sap.fe": {
    "app": {
      "enableLazyLoading": true
    }
  }
}
