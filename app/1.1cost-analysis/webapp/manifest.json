{
  "_version": "1.85.0",
  "sap.app": {
    "id": "com.medicare.11costanalysis",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "dataSources": {
      "mainService": {
        "uri": "/medicare/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.148.1",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {},
        "sap.ui.layout": {},
        "sap.viz": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "com.medicare.11costanalysis.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": ":?query:",
          "name": "CostAnalysisV2List",
          "target": "CostAnalysisV2List"
        },
        {
          "pattern": "CostAnalysisV2({key}):?query:",
          "name": "CostAnalysisV2ObjectPage",
          "target": "CostAnalysisV2ObjectPage"
        }
      ],
      "targets": {
        "CostAnalysisV2List": {
          "type": "Component",
          "id": "CostAnalysisV2List",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/CostAnalysisV2",
              "variantManagement": "Page",
              "defaultTemplateAnnotationPath": "com.sap.vocabularies.UI.v1.SelectionPresentationVariant#ALPDashboard",
              "keyPerformanceIndicators": {
                "RejectedChargesKPI": {
                  "entitySet": "CostAnalysisV2",
                  "qualifier": "RejectedChargesKPI"
                },
                "TopSpendingState": {
                  "entitySet": "CostAnalysisV2",
                  "qualifier": "TopSpendingState"
                }
              },
              "navigation": {
                "CostAnalysisV2": {
                  "detail": {
                    "route": "CostAnalysisV2ObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "AnalyticalTable",
                    "selectionMode": "None",
                    "enableExport": true
                  },
                  "actions": {
                    "openDiagram": {
                      "id": "openAiDiagram",
                      "text": "{{Generate_Diagram}}",
                      "press": ".extension.com.medicare.11costanalysis.controller.ListReportExt.openDiagram",
                      "requiresSelection": false
                    }
                  }
                },
                "@com.sap.vocabularies.UI.v1.Chart#V2Footprint": {
                  "chartSettings": {
                    "defaultChartType": "column",
                    "vizProperties": {
                      "plotArea": {
                        "dataPointSize": {
                          "min": 80,
                          "max": 80
                        }
                      },
                      "interaction": {
                        "zoom": {
                          "enablement": "enabled"
                        }
                      }
                    }
                  },
                  "requestFilterFields": [
                    "StateName"
                  ]
                },
                "@com.sap.vocabularies.UI.v1.SelectionFields": {
                  "filterFields": {
                    "State": {
                      "propertyInfo": {
                        "valueList": "@com.sap.vocabularies.Common.v1.ValueList#StateCrossFilter"
                      }
                    }
                  }
                }
              },
              "views": {
                "paths": [
                  {
                    "primary": [
                      {
                        "annotationPath": "com.sap.vocabularies.UI.v1.PresentationVariant#V2Chart"
                      }
                    ],
                    "secondary": [
                      {
                        "annotationPath": "com.sap.vocabularies.UI.v1.PresentationVariant#V2Table"
                      }
                    ],
                    "defaultPath": "both"
                  }
                ]
              }
            }
          }
        },
        "CostAnalysisV2ObjectPage": {
          "type": "Component",
          "id": "CostAnalysisV2ObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/CostAnalysisV2"
            }
          }
        }
      }
    },
    "extends": {
      "extensions": {
        "sap.ui.controllerExtensions": {
          "sap.fe.templates.ListReport.ListReportController": {
            "controllerName": "com.medicare.11costanalysis.controller.ListReportExt"
          }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "analytical"
  },
  "sap.fe": {
    "app": {
      "enableLazyLoading": true
    }
  }
}
