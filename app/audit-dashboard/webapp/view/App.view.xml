<mvc:View
    controllerName="com.medicare.auditdashboard.controller.App"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:tnt="sap.tnt"
    xmlns:f="sap.f"
    xmlns:grid="sap.ui.layout.cssgrid"
    xmlns:card="sap.f.cards"
    xmlns:core="sap.ui.core"
    xmlns:vbm="sap.ui.vbm"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:vizData="sap.viz.ui5.data"
    xmlns:vizFeeds="sap.viz.ui5.controls.common.feeds"
    displayBlock="true"
    height="100%">

    <tnt:ToolPage id="toolPage" class="medDashPage">

        <!-- ── Top header ──────────────────────────────────────────────── -->
        <tnt:header>
            <tnt:ToolHeader class="medDashHeader">
                <Button icon="sap-icon://menu2" type="Transparent" press=".onMenuToggle" tooltip="Toggle navigation"/>
                <Title text="SAP" class="medDashLogo"/>
                <ToolbarSpacer width="1rem"/>
                <Title text="Medicare Analytics Overview" level="H4" class="medDashTitle"/>
                <ToolbarSpacer/>
                <SearchField width="16rem" placeholder="Search providers, states…" class="medDashSearch"/>
                <Button icon="sap-icon://filter" type="Transparent" tooltip="Filters"/>
                <Button icon="sap-icon://bell" type="Transparent" tooltip="Notifications"/>
                <Avatar initials="JD" displaySize="XS" backgroundColor="Accent6" class="sapUiTinyMarginBegin"/>
            </tnt:ToolHeader>
        </tnt:header>

        <!-- ── Left navigation rail ────────────────────────────────────── -->
        <tnt:sideContent>
            <tnt:SideNavigation id="sideNav" expanded="true" selectedKey="overview">
                <tnt:NavigationList>
                    <tnt:NavigationListItem text="Overview"          key="overview"   icon="sap-icon://home"/>
                    <tnt:NavigationListItem text="Cost Analysis"     key="cost"       icon="sap-icon://money-bills"/>
                    <tnt:NavigationListItem text="Provider Analysis" key="provider"   icon="sap-icon://person-placeholder"/>
                    <tnt:NavigationListItem text="Utilization"       key="util"       icon="sap-icon://bar-chart"/>
                    <tnt:NavigationListItem text="Geography"         key="geo"        icon="sap-icon://map-3"/>
                    <tnt:NavigationListItem text="Benchmarks"        key="bench"      icon="sap-icon://measure"/>
                    <tnt:NavigationListItem text="Alerts"            key="alerts"     icon="sap-icon://alert"/>
                    <tnt:NavigationListItem text="Reports"           key="reports"    icon="sap-icon://document-text"/>
                </tnt:NavigationList>
                <tnt:fixedItem>
                    <tnt:NavigationList>
                        <tnt:NavigationListItem text="Settings" key="settings" icon="sap-icon://action-settings"/>
                    </tnt:NavigationList>
                </tnt:fixedItem>
            </tnt:SideNavigation>
        </tnt:sideContent>

        <!-- ── Main dashboard content ──────────────────────────────────── -->
        <tnt:mainContents>
            <ScrollContainer height="100%" width="100%" vertical="true" horizontal="false" class="medDashScroll">
                <grid:CSSGrid class="medDashGrid" gridTemplateColumns="repeat(12, 1fr)" gridGap="1rem">

                    <!-- ══ Section · Key Metrics ════════════════════════════════ -->
                    <Title text="Key Metrics" level="H3" class="medSectionTitle medFirstSection">
                        <layoutData><grid:GridItemLayoutData gridColumn="span 12"/></layoutData>
                    </Title>

                    <!-- KPI 1: Total Medicare Spend -->
                    <f:Card class="medKpiCard">
                        <f:layoutData><grid:GridItemLayoutData gridColumn="span 3"/></f:layoutData>
                        <f:header>
                            <card:NumericHeader
                                title="Total Medicare Spend"
                                number="{dash>/kpi/spendNum}"
                                scale="{dash>/kpi/spendScale}"
                                trend="{dash>/kpi/spendDir}"
                                state="{dash>/kpi/spendState}"
                                details="{dash>/kpi/spendTrend} vs PY"/>
                        </f:header>
                    </f:Card>

                    <!-- KPI 2: Total Providers -->
                    <f:Card class="medKpiCard">
                        <f:layoutData><grid:GridItemLayoutData gridColumn="span 3"/></f:layoutData>
                        <f:header>
                            <card:NumericHeader
                                title="Total Providers"
                                number="{dash>/kpi/provNum}"
                                scale="{dash>/kpi/provScale}"
                                trend="{dash>/kpi/provDir}"
                                state="{dash>/kpi/provState}"
                                details="{dash>/kpi/provTrend} vs PY"/>
                        </f:header>
                    </f:Card>

                    <!-- KPI 3: Avg HCC Risk Score -->
                    <f:Card class="medKpiCard">
                        <f:layoutData><grid:GridItemLayoutData gridColumn="span 3"/></f:layoutData>
                        <f:header>
                            <card:NumericHeader
                                title="Avg HCC Risk Score"
                                number="{dash>/kpi/riskNum}"
                                trend="{dash>/kpi/riskDir}"
                                state="{dash>/kpi/riskState}"
                                details="{dash>/kpi/riskTrend} vs PY"/>
                        </f:header>
                    </f:Card>

                    <!-- KPI 4: Beneficiaries -->
                    <f:Card class="medKpiCard">
                        <f:layoutData><grid:GridItemLayoutData gridColumn="span 3"/></f:layoutData>
                        <f:header>
                            <card:NumericHeader
                                title="Beneficiaries"
                                number="{dash>/kpi/beneNum}"
                                scale="{dash>/kpi/beneScale}"
                                trend="{dash>/kpi/beneDir}"
                                state="{dash>/kpi/beneState}"
                                details="{dash>/kpi/beneTrend} vs PY"/>
                        </f:header>
                    </f:Card>

                    <!-- ══ Section · Cost &amp; Geography ═══════════════════════════ -->
                    <Title text="Cost &amp; Geography" level="H3" class="medSectionTitle">
                        <layoutData><grid:GridItemLayoutData gridColumn="span 12"/></layoutData>
                    </Title>

                    <!-- Cost by State (choropleth) -->
                    <f:Card class="medChartCard">
                        <f:layoutData><grid:GridItemLayoutData gridColumn="span 5"/></f:layoutData>
                        <f:header>
                            <card:Header title="Cost by State" subtitle="Total Medicare Paid · 2023"/>
                        </f:header>
                        <f:content>
                            <VBox height="470px" class="medMapBox">
                                <vbm:AnalyticMap id="vbiMap" width="100%" height="470px"
                                    initialPosition="-96;39;0" initialZoom="3"
                                    regions="{dash>/mapRegions}"
                                    regionClick=".onRegionClick">
                                    <vbm:regions>
                                        <vbm:Region code="{dash>code}" color="{dash>color}" tooltip="{dash>tooltip}"/>
                                    </vbm:regions>
                                    <vbm:legend>
                                        <vbm:Legend id="mapLegend" caption="Total Medicare Paid" items="{dash>/mapLegend}">
                                            <vbm:LegendItem text="{dash>text}" color="{dash>color}"/>
                                        </vbm:Legend>
                                    </vbm:legend>
                                </vbm:AnalyticMap>
                            </VBox>
                        </f:content>
                    </f:Card>

                    <!-- Cost by Provider Type (Top 10) -->
                    <f:Card class="medChartCard">
                        <f:layoutData><grid:GridItemLayoutData gridColumn="span 4"/></f:layoutData>
                        <f:header>
                            <card:Header title="Cost by Provider Type" subtitle="Top 10 specialties by Total Paid · 2023"/>
                        </f:header>
                        <f:content>
                            <viz:VizFrame id="vizProviderType" vizType="bar" height="470px" width="100%"
                                uiConfig="{applicationSet:'fiori'}">
                                <viz:dataset>
                                    <vizData:FlattenedDataset data="{dash>/providerType}">
                                        <vizData:dimensions>
                                            <vizData:DimensionDefinition name="Specialty" value="{dash>name}"/>
                                        </vizData:dimensions>
                                        <vizData:measures>
                                            <vizData:MeasureDefinition name="Total Paid" value="{dash>value}"/>
                                        </vizData:measures>
                                    </vizData:FlattenedDataset>
                                </viz:dataset>
                                <viz:feeds>
                                    <vizFeeds:FeedItem uid="valueAxis" type="Measure" values="Total Paid"/>
                                    <vizFeeds:FeedItem uid="categoryAxis" type="Dimension" values="Specialty"/>
                                </viz:feeds>
                            </viz:VizFrame>
                        </f:content>
                    </f:Card>

                    <!-- Cost insights: highest / lowest / average per category -->
                    <f:Card class="medChartCard medInsightCard">
                        <f:layoutData><grid:GridItemLayoutData gridColumn="span 3"/></f:layoutData>
                        <f:header>
                            <card:Header title="Cost Highlights" subtitle="Highest · Lowest · Average · 2023"/>
                        </f:header>
                        <f:content>
                            <List items="{dash>/insights/cost}" showSeparators="None"
                                backgroundDesign="Transparent" class="medInsightList">
                                <CustomListItem class="medInsightLi">
                                    <VBox class="medInsightRow">
                                        <Text text="{dash>cat}" class="medInsightCat"/>
                                        <HBox class="medInsightLine" justifyContent="SpaceBetween" alignItems="Center">
                                            <Text text="HIGH" class="medInsightTag medTagHigh"/>
                                            <Text text="{dash>high/label}" wrapping="false" class="medInsightName">
                                                <layoutData><FlexItemData growFactor="1" baseSize="0%"/></layoutData>
                                            </Text>
                                            <Text text="{dash>high/value}" class="medInsightVal"/>
                                        </HBox>
                                        <HBox class="medInsightLine" justifyContent="SpaceBetween" alignItems="Center">
                                            <Text text="LOW" class="medInsightTag medTagLow"/>
                                            <Text text="{dash>low/label}" wrapping="false" class="medInsightName">
                                                <layoutData><FlexItemData growFactor="1" baseSize="0%"/></layoutData>
                                            </Text>
                                            <Text text="{dash>low/value}" class="medInsightVal"/>
                                        </HBox>
                                        <HBox class="medInsightLine" justifyContent="SpaceBetween" alignItems="Center">
                                            <Text text="AVG" class="medInsightTag medTagAvg"/>
                                            <Text text="" wrapping="false" class="medInsightName">
                                                <layoutData><FlexItemData growFactor="1" baseSize="0%"/></layoutData>
                                            </Text>
                                            <Text text="{dash>avg/value}" class="medInsightVal"/>
                                        </HBox>
                                    </VBox>
                                </CustomListItem>
                            </List>
                        </f:content>
                    </f:Card>

                    <!-- ══ Section · Population &amp; Risk ══════════════════════════ -->
                    <Title text="Population &amp; Risk" level="H3" class="medSectionTitle">
                        <layoutData><grid:GridItemLayoutData gridColumn="span 12"/></layoutData>
                    </Title>

                    <!-- Rural vs Urban Distribution -->
                    <f:Card class="medChartCard">
                        <f:layoutData><grid:GridItemLayoutData gridColumn="span 3"/></f:layoutData>
                        <f:header>
                            <card:Header title="Rural vs Urban Distribution" subtitle="Beneficiaries · 2023"/>
                        </f:header>
                        <f:content>
                            <viz:VizFrame id="vizRuralUrban" vizType="donut" height="290px" width="100%"
                                uiConfig="{applicationSet:'fiori'}">
                                <viz:dataset>
                                    <vizData:FlattenedDataset data="{dash>/ruralUrban}">
                                        <vizData:dimensions>
                                            <vizData:DimensionDefinition name="Segment" value="{dash>name}"/>
                                        </vizData:dimensions>
                                        <vizData:measures>
                                            <vizData:MeasureDefinition name="Beneficiaries" value="{dash>value}"/>
                                        </vizData:measures>
                                    </vizData:FlattenedDataset>
                                </viz:dataset>
                                <viz:feeds>
                                    <vizFeeds:FeedItem uid="size" type="Measure" values="Beneficiaries"/>
                                    <vizFeeds:FeedItem uid="color" type="Dimension" values="Segment"/>
                                </viz:feeds>
                            </viz:VizFrame>
                        </f:content>
                    </f:Card>

                    <!-- Risk Score Distribution -->
                    <f:Card class="medChartCard">
                        <f:layoutData><grid:GridItemLayoutData gridColumn="span 3"/></f:layoutData>
                        <f:header>
                            <card:Header title="Risk Score Distribution" subtitle="Providers by risk band · 2023"/>
                        </f:header>
                        <f:content>
                            <viz:VizFrame id="vizRiskDist" vizType="column" height="290px" width="100%"
                                uiConfig="{applicationSet:'fiori'}">
                                <viz:dataset>
                                    <vizData:FlattenedDataset data="{dash>/riskDist}">
                                        <vizData:dimensions>
                                            <vizData:DimensionDefinition name="Risk Band" value="{dash>name}"/>
                                        </vizData:dimensions>
                                        <vizData:measures>
                                            <vizData:MeasureDefinition name="Providers" value="{dash>value}"/>
                                        </vizData:measures>
                                    </vizData:FlattenedDataset>
                                </viz:dataset>
                                <viz:feeds>
                                    <vizFeeds:FeedItem uid="valueAxis" type="Measure" values="Providers"/>
                                    <vizFeeds:FeedItem uid="categoryAxis" type="Dimension" values="Risk Band"/>
                                </viz:feeds>
                            </viz:VizFrame>
                        </f:content>
                    </f:Card>

                    <!-- Top Cost Outliers -->
                    <f:Card class="medChartCard">
                        <f:layoutData><grid:GridItemLayoutData gridColumn="span 3"/></f:layoutData>
                        <f:header>
                            <card:Header title="Top Cost Outliers" subtitle="By cost intensity · 2023"/>
                        </f:header>
                        <f:content>
                            <Table id="outlierTable" items="{dash>/outliers}" class="medOutlierTable"
                                fixedLayout="false" showSeparators="Inner">
                                <columns>
                                    <Column><Text text="Provider"/></Column>
                                    <Column><Text text="Specialty"/></Column>
                                    <Column hAlign="End"><Text text="Cost/Bene"/></Column>
                                </columns>
                                <items>
                                    <ColumnListItem>
                                        <cells>
                                            <Text text="{dash>provider}"/>
                                            <Text text="{dash>specialty}"/>
                                            <ObjectNumber number="{dash>cost}" unit="$" state="Error"/>
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </f:content>
                    </f:Card>

                    <!-- Population insights: highest / lowest / average per category -->
                    <f:Card class="medChartCard medInsightCard">
                        <f:layoutData><grid:GridItemLayoutData gridColumn="span 3"/></f:layoutData>
                        <f:header>
                            <card:Header title="Population Highlights" subtitle="Highest · Lowest · Average · 2023"/>
                        </f:header>
                        <f:content>
                            <List items="{dash>/insights/pop}" showSeparators="None"
                                backgroundDesign="Transparent" class="medInsightList">
                                <CustomListItem class="medInsightLi">
                                    <VBox class="medInsightRow">
                                        <Text text="{dash>cat}" class="medInsightCat"/>
                                        <HBox class="medInsightLine" justifyContent="SpaceBetween" alignItems="Center">
                                            <Text text="HIGH" class="medInsightTag medTagHigh"/>
                                            <Text text="{dash>high/label}" wrapping="false" class="medInsightName">
                                                <layoutData><FlexItemData growFactor="1" baseSize="0%"/></layoutData>
                                            </Text>
                                            <Text text="{dash>high/value}" class="medInsightVal"/>
                                        </HBox>
                                        <HBox class="medInsightLine" justifyContent="SpaceBetween" alignItems="Center">
                                            <Text text="LOW" class="medInsightTag medTagLow"/>
                                            <Text text="{dash>low/label}" wrapping="false" class="medInsightName">
                                                <layoutData><FlexItemData growFactor="1" baseSize="0%"/></layoutData>
                                            </Text>
                                            <Text text="{dash>low/value}" class="medInsightVal"/>
                                        </HBox>
                                        <HBox class="medInsightLine" justifyContent="SpaceBetween" alignItems="Center">
                                            <Text text="AVG" class="medInsightTag medTagAvg"/>
                                            <Text text="" wrapping="false" class="medInsightName">
                                                <layoutData><FlexItemData growFactor="1" baseSize="0%"/></layoutData>
                                            </Text>
                                            <Text text="{dash>avg/value}" class="medInsightVal"/>
                                        </HBox>
                                    </VBox>
                                </CustomListItem>
                            </List>
                        </f:content>
                    </f:Card>

                    <!-- ══ Task 3 · Association Analysis ════════════════════════ -->
                    <Title text="Association Analysis" level="H3" class="medSectionTitle">
                        <layoutData><grid:GridItemLayoutData gridColumn="span 12"/></layoutData>
                    </Title>

                    <!-- Risk ↔ Payment by Specialty (bubble) -->
                    <f:Card class="medChartCard">
                        <f:layoutData><grid:GridItemLayoutData gridColumn="span 5"/></f:layoutData>
                        <f:header>
                            <card:Header title="Patient Risk vs Payment" subtitle="Paid/Bene vs Avg HCC risk · bubble = beneficiaries · Top 15 specialties · 2023"/>
                        </f:header>
                        <f:content>
                            <viz:VizFrame id="vizRiskPay" vizType="bubble" height="330px" width="100%"
                                uiConfig="{applicationSet:'fiori'}">
                                <viz:dataset>
                                    <vizData:FlattenedDataset data="{dash>/riskAssoc}">
                                        <vizData:dimensions>
                                            <vizData:DimensionDefinition name="Specialty" value="{dash>type}"/>
                                        </vizData:dimensions>
                                        <vizData:measures>
                                            <vizData:MeasureDefinition name="Avg Risk Score" value="{dash>risk}"/>
                                            <vizData:MeasureDefinition name="Paid per Beneficiary" value="{dash>paid}"/>
                                            <vizData:MeasureDefinition name="Beneficiaries" value="{dash>benes}"/>
                                        </vizData:measures>
                                    </vizData:FlattenedDataset>
                                </viz:dataset>
                                <viz:feeds>
                                    <vizFeeds:FeedItem uid="valueAxis"  type="Measure"   values="Avg Risk Score"/>
                                    <vizFeeds:FeedItem uid="valueAxis2" type="Measure"   values="Paid per Beneficiary"/>
                                    <vizFeeds:FeedItem uid="bubbleWidth" type="Measure"  values="Beneficiaries"/>
                                    <vizFeeds:FeedItem uid="color"      type="Dimension" values="Specialty"/>
                                </viz:feeds>
                            </viz:VizFrame>
                        </f:content>
                    </f:Card>

                    <!-- Charge Gap by Credential (bar) -->
                    <f:Card class="medChartCard">
                        <f:layoutData><grid:GridItemLayoutData gridColumn="span 4"/></f:layoutData>
                        <f:header>
                            <card:Header title="Charge Gap by Credential" subtitle="Paid-to-charge &amp; allowed-to-charge ratio · Top 8 by providers · 2023"/>
                        </f:header>
                        <f:content>
                            <viz:VizFrame id="vizCredGap" vizType="bar" height="330px" width="100%"
                                uiConfig="{applicationSet:'fiori'}">
                                <viz:dataset>
                                    <vizData:FlattenedDataset data="{dash>/credGap}">
                                        <vizData:dimensions>
                                            <vizData:DimensionDefinition name="Credential" value="{dash>cred}"/>
                                        </vizData:dimensions>
                                        <vizData:measures>
                                            <vizData:MeasureDefinition name="Allowed / Charge %" value="{dash>allowedPct}"/>
                                            <vizData:MeasureDefinition name="Paid / Charge %" value="{dash>paidPct}"/>
                                        </vizData:measures>
                                    </vizData:FlattenedDataset>
                                </viz:dataset>
                                <viz:feeds>
                                    <vizFeeds:FeedItem uid="valueAxis"   type="Measure"   values="Allowed / Charge %,Paid / Charge %"/>
                                    <vizFeeds:FeedItem uid="categoryAxis" type="Dimension" values="Credential"/>
                                </viz:feeds>
                            </viz:VizFrame>
                        </f:content>
                    </f:Card>

                    <!-- Association insights: highest / lowest / average per category -->
                    <f:Card class="medChartCard medInsightCard">
                        <f:layoutData><grid:GridItemLayoutData gridColumn="span 3"/></f:layoutData>
                        <f:header>
                            <card:Header title="Association Highlights" subtitle="Highest · Lowest · Average · 2023"/>
                        </f:header>
                        <f:content>
                            <List items="{dash>/insights/assoc}" showSeparators="None"
                                backgroundDesign="Transparent" class="medInsightList">
                                <CustomListItem class="medInsightLi">
                                    <VBox class="medInsightRow">
                                        <Text text="{dash>cat}" class="medInsightCat"/>
                                        <HBox class="medInsightLine" justifyContent="SpaceBetween" alignItems="Center">
                                            <Text text="HIGH" class="medInsightTag medTagHigh"/>
                                            <Text text="{dash>high/label}" wrapping="false" class="medInsightName">
                                                <layoutData><FlexItemData growFactor="1" baseSize="0%"/></layoutData>
                                            </Text>
                                            <Text text="{dash>high/value}" class="medInsightVal"/>
                                        </HBox>
                                        <HBox class="medInsightLine" justifyContent="SpaceBetween" alignItems="Center">
                                            <Text text="LOW" class="medInsightTag medTagLow"/>
                                            <Text text="{dash>low/label}" wrapping="false" class="medInsightName">
                                                <layoutData><FlexItemData growFactor="1" baseSize="0%"/></layoutData>
                                            </Text>
                                            <Text text="{dash>low/value}" class="medInsightVal"/>
                                        </HBox>
                                        <HBox class="medInsightLine" justifyContent="SpaceBetween" alignItems="Center">
                                            <Text text="AVG" class="medInsightTag medTagAvg"/>
                                            <Text text="" wrapping="false" class="medInsightName">
                                                <layoutData><FlexItemData growFactor="1" baseSize="0%"/></layoutData>
                                            </Text>
                                            <Text text="{dash>avg/value}" class="medInsightVal"/>
                                        </HBox>
                                    </VBox>
                                </CustomListItem>
                            </List>
                        </f:content>
                    </f:Card>

                    <!-- Facility vs Office charges (column) -->
                    <f:Card class="medChartCard">
                        <f:layoutData><grid:GridItemLayoutData gridColumn="span 7"/></f:layoutData>
                        <f:header>
                            <card:Header title="Facility vs Office Charges" subtitle="Volume-weighted avg per service line · 2023"/>
                        </f:header>
                        <f:content>
                            <viz:VizFrame id="vizPlace" vizType="column" height="290px" width="100%"
                                uiConfig="{applicationSet:'fiori'}">
                                <viz:dataset>
                                    <vizData:FlattenedDataset data="{dash>/placeCharge}">
                                        <vizData:dimensions>
                                            <vizData:DimensionDefinition name="Place of Service" value="{dash>place}"/>
                                        </vizData:dimensions>
                                        <vizData:measures>
                                            <vizData:MeasureDefinition name="Submitted" value="{dash>submitted}"/>
                                            <vizData:MeasureDefinition name="Allowed" value="{dash>allowed}"/>
                                            <vizData:MeasureDefinition name="Paid" value="{dash>paid}"/>
                                        </vizData:measures>
                                    </vizData:FlattenedDataset>
                                </viz:dataset>
                                <viz:feeds>
                                    <vizFeeds:FeedItem uid="valueAxis"   type="Measure"   values="Submitted,Allowed,Paid"/>
                                    <vizFeeds:FeedItem uid="categoryAxis" type="Dimension" values="Place of Service"/>
                                </viz:feeds>
                            </viz:VizFrame>
                        </f:content>
                    </f:Card>

                    <!-- Where care is delivered (service volume split) -->
                    <f:Card class="medChartCard">
                        <f:layoutData><grid:GridItemLayoutData gridColumn="span 5"/></f:layoutData>
                        <f:header>
                            <card:Header title="Where Care Is Delivered" subtitle="Total services by place of service · 2023"/>
                        </f:header>
                        <f:content>
                            <viz:VizFrame id="vizPlaceVol" vizType="donut" height="290px" width="100%"
                                uiConfig="{applicationSet:'fiori'}">
                                <viz:dataset>
                                    <vizData:FlattenedDataset data="{dash>/placeVolume}">
                                        <vizData:dimensions>
                                            <vizData:DimensionDefinition name="Place" value="{dash>name}"/>
                                        </vizData:dimensions>
                                        <vizData:measures>
                                            <vizData:MeasureDefinition name="Services" value="{dash>value}"/>
                                        </vizData:measures>
                                    </vizData:FlattenedDataset>
                                </viz:dataset>
                                <viz:feeds>
                                    <vizFeeds:FeedItem uid="size"  type="Measure"   values="Services"/>
                                    <vizFeeds:FeedItem uid="color" type="Dimension" values="Place"/>
                                </viz:feeds>
                            </viz:VizFrame>
                        </f:content>
                    </f:Card>

                </grid:CSSGrid>
            </ScrollContainer>
        </tnt:mainContents>
    </tnt:ToolPage>
</mvc:View>
