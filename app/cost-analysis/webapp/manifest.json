{
  "_version": "1.85.0",
  "sap.app": {
    "id": "com.medicare.costanalysis",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:alp",
      "version": "1.25.0",
      "toolsId": "6ed8e069-6c10-42f6-80a5-7c2307529236"
    },
    "dataSources": {
      "mainService": {
        "uri": "/medicare/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.148.1",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "com.medicare.costanalysis.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": []
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": ":?query:",
          "name": "CostByStateProviderTypeList",
          "target": "CostByStateProviderTypeList"
        },
        {
          "pattern": "CostByStateProviderType({key}):?query:",
          "name": "CostByStateProviderTypeObjectPage",
          "target": "CostByStateProviderTypeObjectPage"
        }
      ],
      "targets": {
        "CostByStateProviderTypeList": {
          "type": "Component",
          "id": "CostByStateProviderTypeList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/CostByStateProviderType",
              "variantManagement": "Page",
              "defaultTemplateAnnotationPath": "com.sap.vocabularies.UI.v1.SelectionPresentationVariant#ALPDashboard",
              "navigation": {
                "CostByStateProviderType": {
                  "detail": {
                    "route": "CostByStateProviderTypeObjectPage"
                  }
                }
              },
              "keyPerformanceIndicators": {
                "TotalPaidKPI": {
                  "entitySet": "CostByStateProviderType",
                  "qualifier": "TotalPaidKPI"
                },
                "TotalBeneficiariesKPI": {
                  "entitySet": "CostByStateProviderType",
                  "qualifier": "TotalBeneficiariesKPI"
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "AnalyticalTable",
                    "selectionMode": "None",
                    "enableExport": true
                  }
                },
                "@com.sap.vocabularies.UI.v1.Chart": {
                  "chartSettings": {
                    "defaultChartType": "column",
                    "vizProperties": {
                      "plotArea": {
                        "dataPointSize": { "min": 80, "max": 80 }
                      },
                      "interaction": {
                        "zoom": { "enablement": "enabled" }
                      }
                    }
                  }
                },
                "@com.sap.vocabularies.UI.v1.Chart#FinancialHealth": {
                  "chartSettings": {
                    "defaultChartType": "column",
                    "vizProperties": {
                      "plotArea": {
                        "dataPointSize": { "min": 80, "max": 80 }
                      },
                      "interaction": {
                        "zoom": { "enablement": "enabled" }
                      }
                    }
                  }
                },
                "@com.sap.vocabularies.UI.v1.Chart#DrugParticipation": {
                  "chartSettings": {
                    "defaultChartType": "column"
                  }
                },
                "@com.sap.vocabularies.UI.v1.Chart#StateBreakdown": {
                  "chartSettings": {
                    "defaultChartType": "column"
                  },
                  "requestFilterFields": ["State"]
                },
                "@com.sap.vocabularies.UI.v1.SelectionFields": {
                  "filterFields": {
                    "State": {
                      "visualFilter": {
                        "valueList": "@com.sap.vocabularies.Common.v1.ValueList#VFState"
                      },
                      "propertyInfo": {
                        "valueList": "@com.sap.vocabularies.Common.v1.ValueList#StateCrossFilter"
                      }
                    },
                    "ProviderType": {
                      "visualFilter": {
                        "valueList": "@com.sap.vocabularies.Common.v1.ValueList#VFProviderType"
                      }
                    },
                    "MedicareParticipating": {
                      "visualFilter": {
                        "valueList": "@com.sap.vocabularies.Common.v1.ValueList#DrugParticipationVF"
                      }
                    }
                  }
                }
              },
              "views": {
                "paths": [
                  {
                    "primary": [
                      {
                        "annotationPath": "com.sap.vocabularies.UI.v1.PresentationVariant#FinancialHealth"
                      }
                    ],
                    "secondary": [
                      {
                        "annotationPath": "com.sap.vocabularies.UI.v1.PresentationVariant"
                      }
                    ],
                    "defaultPath": "both"
                  }
                ]
              }
            }
          }
        },
        "CostByStateProviderTypeObjectPage": {
          "type": "Component",
          "id": "CostByStateProviderTypeObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/CostByStateProviderType"
            }
          }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "analytical"
  },
  "sap.fe": {
    "app": {
      "enableLazyLoading": true
    }
  }
}
